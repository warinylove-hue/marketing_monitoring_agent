# OpenAI API key for AI chat.
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Google Sheet target.
# Vercel 배포에서는 GOOGLE_SPREADSHEET_ID 입력을 권장합니다.
GOOGLE_SPREADSHEET_ID=
GOOGLE_SPREADSHEET_NAME=마케팅_크롤링_DB

# Local development only.
# 로컬에서는 기존 서비스 계정 JSON 파일을 그대로 사용할 수 있습니다.
GOOGLE_APPLICATION_CREDENTIALS=../site-monitoriing-project-c639a6c0fe66.json

# Vercel deployment.
# 서비스 계정 JSON 파일의 client_email 값을 넣으세요.
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# 서비스 계정 JSON 파일의 private_key 값을 넣으세요.
# Vercel에는 줄바꿈을 \n 형태로 넣으면 됩니다.
# 예: -----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
GOOGLE_PRIVATE_KEY=

# Cloud Run Job manual trigger from dashboard.
# Vercel의 "지금 자료 수집하기" 버튼이 아래 Job을 실행합니다.
GOOGLE_CLOUD_PROJECT_ID=site-monitoriing-project
CLOUD_RUN_REGION=asia-northeast3
CLOUD_RUN_JOB_NAME=marketing-crawler-job

# Optional legacy trigger URL. Normally empty when using Cloud Run Job settings above.
CLOUD_CRAWLER_TRIGGER_URL=
CLOUD_CRAWLER_TRIGGER_TOKEN=
